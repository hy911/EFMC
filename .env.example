# ===== 数据库 =====
# PostgreSQL 连接串（docker-compose 部署时主机名用服务名 postgres）
DATABASE_URL=postgres://payload:payload@127.0.0.1:5432/efmc

# ===== Payload =====
# 加密密钥：openssl rand -hex 32 生成，生产环境必须替换
PAYLOAD_SECRET=YOUR_SECRET_HERE

# ===== 站点 =====
# 站点对外的绝对 URL（影响 hreflang、sitemap、OG 标签、邮件里的链接）
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ===== 询盘：邮件通知（Resend）=====
# 留空则跳过邮件通知（询盘仍会写入数据库）
RESEND_API_KEY=
# 通知收件人（运营邮箱）
INQUIRY_NOTIFY_TO=
# 发件地址（需在 Resend 验证过的域名）
INQUIRY_NOTIFY_FROM=noreply@example.com

# ===== 询盘：Cloudflare Turnstile 防垃圾 =====
# 留空则跳过人机校验（本地开发方便；生产环境必须配置）
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
